# FMP API key is stored as a Databricks UC secret — NOT as an environment variable.
# To create the secret:
#   databricks secrets create-scope --scope awm-demo
#   databricks secrets put-secret --scope awm-demo --key fmp-api-key
#
# The scope and key names are configured in utils/config.py:
#   SECRET_SCOPE   = "awm-demo"
#   SECRET_KEY_FMP = "fmp-api-key"

# Unity Catalog paths are set directly in utils/config.py (no env vars needed):
#   UC_CATALOG     = "uc"
#   UC_SCHEMA      = "wealth"
#   UC_VOLUME_PATH = "/Volumes/uc/wealth/documents"
